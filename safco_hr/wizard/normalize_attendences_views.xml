
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="normalize_attendences_view_form" model="ir.ui.view">
        <field name="name">normalize.attendences.form</field>
        <field name="model">normalize.attendences</field>
        <field name="arch" type="xml">
            <form string="normalize.attendences">
                <sheet>
                    <group>
                        <div class="oe_form_box_info bg-info oe_text_center">
                            <p><strong>All chosen records will be adjusted</strong></p>
                        </div>
                    </group>
                </sheet>
                <footer>
                    <button string="Normalize attendences" type="object" class="btn-primary" name="action_normalize_attendences"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_normalize_attendences" model="ir.actions.server">
        <field name="name">Normalize selected attendences</field>
        <field name="model_id" ref="safco_hr.model_normalize_attendences"/>
        <field name="binding_model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = model.action_normalize_attendences_wizard()</field>
    </record>
</odoo>
