<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="safco_hr_hr_contract_form" model="ir.ui.view">
        <field name="name">hr.contract</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_end']" position="after">
                <label for="notice_days"/>
                <div class="o_row">
                    <field name="notice_days"/>
                    <span> days</span>
                </div>
            </xpath>
            <xpath expr="//field[@name='hr_responsible_id']" position="after">
                <field name="default_struct_id"/>
            </xpath>
            <field name="name" position="attributes">
                <attribute name="readonly">True</attribute>
            </field>

             <group name="salary" position="inside">
            <label for="phone_allowance">
            </label>
            <div class="o_row" name="phone_allowance">
                        <field name="phone_allowance" nolabel="1"/>
                        <span>/ month</span>
                    </div>
        </group>
        </field>

    </record>


</odoo>