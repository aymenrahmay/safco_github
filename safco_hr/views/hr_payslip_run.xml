<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="safco_hr_payslip_view_form_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.view.form.safco</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <field name="struct_id" position="after">
                <field name="requested_working_day"/>
            </field>
        </field>
    </record>

        <record id="safco_hr_hr_payroll_structure_type_view_form" model="ir.ui.view">
            <field name="name">hr.payroll.structure.type.form</field>
            <field name="model">hr.payroll.structure.type</field>
            <field name="inherit_id" ref="hr_payroll.hr_payroll_structure_type_view_form"/>
            <field name="arch" type="xml">
                <field name="default_struct_id" position="replace">
                    <field name="default_struct_id"/>
                </field>
            </field>
        </record>
        <record id="safco_hr_hr_payroll_structure_type_view_tree" model="ir.ui.view">
            <field name="name">hr.payroll.structure.type.tree</field>
            <field name="model">hr.payroll.structure.type</field>
            <field name="inherit_id" ref="hr_payroll.hr_payroll_structure_type_view_tree"/>
            <field name="arch" type="xml">
                <field name="default_struct_id" position="replace">
                    <field name="default_struct_id"/>
                </field>
            </field>
        </record>
        <record id="safco_hr_view_hr_payroll_structure_list_view_tree" model="ir.ui.view">
            <field name="name">hr.payroll.structure.tree</field>
            <field name="model">hr.payroll.structure</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payroll_structure_list_view"/>
            <field name="arch" type="xml">
                <field name="type_id" position="replace">
                    <field name="type_id"/>
                </field>
            </field>
        </record>
         <record id="safco_hr_hr_payroll_hr_salary_rule_list" model="ir.ui.view">
            <field name="name">hr.salary.rule.tree</field>
            <field name="model">hr.salary.rule</field>
            <field name="inherit_id" ref="hr_payroll.hr_salary_rule_list"/>
            <field name="arch" type="xml">
                <field name="struct_id" position="replace">
                    <field name="struct_id"/>
                </field>
            </field>
        </record>


        <record id="safco_hr_payslip_run_tree_veiw" model="ir.ui.view">
            <field name="name">safco hr.payslip.run.tree</field>
            <field name="model">hr.payslip.run</field>
            <field name="inherit_id" ref="hr_payroll.hr_payslip_run_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="before">
                    <field name="hr_payslip_run_total"/>
                </field>
            </field>
        </record>


        <record id="safco_view_hr_payslip_tree" model="ir.ui.view">
            <field name="name">safco hr.payslip.tree</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="after">
                    <field name="net_wage"/>
                </field>
            </field>
        </record>
    </data>
</odoo>