<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
       <record model="ir.ui.view" id="safc_view_tree_hr_employee">
            <field name="name">safco_hr_inherited.hr.employee.tree</field>
            <field name="model">hr.employee</field>
            <field name="type">list</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='work_email']" position="replace"/>
                <xpath expr="//field[@name='work_phone']" position="replace">
                    <field name="identification_id"/>
                    <field name="expiry_date"/>
                </xpath>
            </field>
        </record>
        <record model="ir.ui.view" id="hr_employee_inherit_form_view">
            <field name="name">hr.employee.form.view</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='personal_information']/group" position="after">
                    <group name="fam_ids" string="Dependence Details">
                        <field name="fam_ids">
                            <list editable="bottom">
                                <field name="relation_id" required="1"/>
                                <field name="member_name" required="1"/>
                                <field name="birth_date"/>
                                <field name="member_contact"/>
                                <field name="dependent_iqama_id" required="1"/>
                                <field name="dependent_expiry_date" required="1"/>
                            </list>
                        </field>
                    </group>
                </xpath>
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="joining_date"/>
                </xpath>
                <xpath expr="//field[@name='identification_id']" position="replace"/>
                <xpath expr="//field[@name='passport_id']" position="replace"/>
                <xpath expr="//page[@name='personal_information']/group/group[1]" position="after">
                    <group name="identification_id_group" string="National/Iqama Information">
                        <field name="identification_id" string="National/Iqama ID."/>
                        <field name="expiry_date" groups="hr.group_hr_user" invisible="not identification_id"/>
                        <field name="id_attachment_id" groups="hr.group_hr_user" widget="many2many_binary" class="oe_inline" invisible="not identification_id"/>
                    </group>
                    <group name="passport_id_group" string="Passport ID">
                        <field name="passport_id"/>
                        <field name="passport_expiry_date" groups="hr.group_hr_user" invisible="not passport_id"/>
                        <field name="passport_attachment_id" groups="hr.group_hr_user" widget="many2many_binary" class="oe_inline" invisible="not passport_id"/>
                    </group>
                </xpath>
                <xpath expr="//page[@name='personal_information']" position="after">
                    <page string="Insurances">
                        <group>
                            <field name="insurence_ids">
                                <list editable="bottom">
                                    <field name="start_date" required="1"/>
                                    <field name="end_date" required="1"/>
                                    <field name="insurance_type_id" required="1"/>
                                </list>
                            </field>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
