<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock.menu_action_inventory_tree" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('stock.group_adv_location'))]"/>
    </record>

    <record id="view_picking_form_safco_stock" model="ir.ui.view">
        <field name="name">stock.picking.form.safco.stock</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_picking_update_effective_date"
                        string="Update effective date"
                        type="object"
                        class="btn-secondary"
                        groups="base.group_user"
                        invisible="state != 'done'"/>
            </xpath>
        </field>
    </record>
</odoo>
