<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_update_effective_date_form" model="ir.ui.view">
        <field name="name">update.effective.date.form</field>
        <field name="model">update.effective.date</field>
        <field name="arch" type="xml">
            <form string="Update Effective Date">
                <group>
                    <field name="to_apply_date"/>
                </group>
                <footer>
                    <button string="Apply" name="update_effective_date" type="object" class="btn btn-primary"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
