<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_tax_invoice_form_knk">
        <field name="name">tax.invoice.form.inherit.knk</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="invoice_date_supply"/>
                <field name="ref" string="Customer reference"/>
            </xpath>
        </field>
    </record>
    <record id="sip_knk_view_res_partner_form" model="ir.ui.view">
            <field name="name">res.partner.knk.sip</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position='replace'>
                    <field id="company"  name="name"   attrs="{'required' : [('type', '=', 'contact')], 'invisible': [('is_company','=', False)]}"/>
                </xpath>
                 <xpath expr="//field[@name='street2']" position='replace'>
                    <field name="street2" placeholder="Other details" class="o_address_street"/>
                 </xpath>
            </field>
        </record>

</odoo>