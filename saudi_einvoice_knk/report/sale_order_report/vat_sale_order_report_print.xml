<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<template id="external_layout_seti_sale_order">
		<t t-if="o and 'company_id' in o">
        <t t-set="company" t-value="o.company_id"/>
    	</t>
    	<t t-if="not o or not 'company_id' in o">
        <t t-set="company" t-value="res_company"/>
    	</t>
		<div class="header">
	    	<table style="border:1pt solid grey;width:100%;font-size:12px;" width="100%">
	    		<link rel="stylesheet" href="/saudi_einvoice_knk/static/src/css/style.css"/>
	            <tr style="border:none;">
	                <td style="border:none;" colspan="2" width="35%">
	                	<strong><span style="padding-left:5px;" t-field="company.name"/></strong><br/>
	                	<t t-if="company.street">
	                		<span style="padding-left:5px;" t-field="company.street"/><br/>
	                	</t>
	                	<t t-if="company.street2">
	                		<span style="padding-left:5px;" t-field="company.street2"/><br/>
	                	</t>
	                	<t t-if="company.city">
	                		<span style="padding-left:5px;" t-field="company.city"/><br/>
	                	</t>
	                	<t t-if="company.country_id">
	                		<span style="padding-left:5px;" t-field="company.country_id.name"/><br/>
	                	</t>
	                </td>
	                
	                <td   style="border:none;" colspan="3" width="30%" class="text-center"><img t-if="company.logo" t-att-src="image_data_uri(company.logo)" style="height: 50px;width: 200px; " alt="Logo"/></td>

	                <td style="border:none; text-align:right;" colspan="2" width="35%" class="text-right">
	                	<strong>
	                		<span class="text-right arabic" style="padding-right:5px;" t-field="company.arabic_name"/></strong><br/>
	                	<t t-if="company.street">
	                		<span class="text-right arabic" style="padding-right:5px;" t-field="company.arabic_street"/><br/>
	                	</t>
	                	<t t-if="company.street2">
	                		<span class="text-right arabic" style="padding-right:5px;" t-field="company.arabic_street2"/><br/>
	                	</t>
	                	<t t-if="company.city">
	                		<span class="text-right arabic" style="padding-right:5px;" t-field="company.arabic_city"/><br/>
	                	</t>
	                	<t t-if="company.arabic_country">
	                		<span class="text-right arabic" style="padding-right:5px;" t-field="company.arabic_country"/><br/>
	                	</t>
	                </td>
	            </tr>
	        	<tr style="border:none;">
	            	<td style="border:none;" width="16%"> <span class="text-right" style="padding-left:5px;"/>CR No. : </td>
	            	<td style="border:none;" width="16%"> <span class="text-center arabic" t-field="company.company_registry"/> </td>
	            	<td style="border:none;" width="17%"> <span class="text-right arabic" style="padding-right:-6px;">:رقم السجل التجاري</span></td>

	            	<td width="2%" style="border:none;"></td>

	            	<td style="border:none;" width="16%"> <span class="text-right" style="padding-left:5px;">VAT No.: </span> </td>
	            	<td style="border:none;" width="16%"> <span class="text-center arabic" t-field="company.vat"/> </td>
	            	<td style="border:none;text-align:right;" width="17%"> <span class="text-right arabic" style="padding-right:-6px;">:ضريبة القيمة المضافة</span></td>
	            </tr>  
	        </table>

        </div>
        <div class="article o_report_layout_standard">
            <t t-raw="0" />
        </div>
        <div class="footer o_background_footer">
            <div class="text-center" style="font-size:14px;"  >
				<ul class="list-inline">
                    <li t-if="company.partner_id.bank_ids" class="list-inline-item">
						<t t-foreach="company.partner_id.bank_ids[0]" t-as="bank">
                           <b>Our Bank : <span t-field="bank.bank_id.name"/> - IBAN: <span t-field="bank.acc_number"/>- BIC: <span t-field="bank.bank_id.bic"/></b>
                        </t>
                    </li>
                </ul>

                <ul class="list-inline">
                    <li t-if="company.phone" class="list-inline-item"><i class="fa fa-phone" role="img" aria-label="Phone" title="Phone"/> <span t-field="company.phone"/></li>
                    <li t-if="company.email" class="list-inline-item"><i class="fa fa-at" role="img" aria-label="Email" title="Email"/> <span t-field="company.email"/></li>
                    <li t-if="company.website" class="list-inline-item"><i class="fa fa-globe" role="img" aria-label="Website" title="Website"/> <span t-field="company.website"/></li>
                    <li t-if="company.vat" class="list-inline-item"><i class="fa fa-building-o" role="img" aria-label="Fiscal number"/><t t-esc="(company.country_id.vat_label or 'Tax ID').replace(' ','\N{NO-BREAK SPACE}')"/>: <span t-esc="company.vat.replace(' ','\N{NO-BREAK SPACE}')"/></li>
                </ul>
                <div t-field="company.report_footer"/>
                <div t-if="report_type == 'pdf'" class="text-muted">
                    Page:
                    <span class="page"/>
                    of
                    <span class="topage"/>
                </div>
            </div>
        </div>
	</template>

	<template id="report_sale_order_document">
		<t t-call="saudi_einvoice_knk.external_layout_seti_sale_order">
			<t t-foreach="doc" t-as="o">
				<div class="page" style="">
					<link rel="stylesheet" href="/saudi_einvoice_knk/static/src/css/style.css"/>
					<t t-set="company" t-value="res_company"/>

					<div class="font">

					<table style="border:1pt solid grey;width:100%;
    height: 23px;color:black; margin-top:10pt;" class="table-condensed table-sm">
							<tr>
								<td style="padding:1pt;margin:0pt;font-weight: bold;text-align:center;background-color:#016feb;border:none;"><span class="text-right arabic">Commercial offer / عرض سعر </span></td>
							</tr>
					</table>
			        <div class="row">
                        <div name="invoice_address" class="col-6">
                            <address t-field="o.partner_id"
                                t-options='{"widget": "contact", "fields": ["address", "name"], "no_marker": True}' />
							 <br/> VAT number: <span t-field="o.partner_id.vat"/>
                        </div>
			            <div class="col-4">
			            	<p>
			            		<strong>Order ref: </strong><span t-field="o.name"/><br/>
			            		<strong>Order Date: </strong><span t-field="o.date_order"/><br/>
								<strong>Validity Date: </strong><span t-field="o.validity_date"/><br/>
								<strong>Payment term: </strong><span t-field="o.payment_term_id.name"/><br/>
								<strong>Customer classification: </strong><span t-field="o.pricelist_id.name"/><br/>
			            	</p>
						</div>
                        <div class="col-2">

			            </div>
                    </div>
					<table style="border:1pt solid grey;width:100%;color:black; margin-top:0pt; color:black;" class="table-condensed">
						<thead>
							<b>
							<tr style="background-color:#016feb">
								<td width="7%" style="border:1pt solid grey;text-align:left;padding:2pt; ">Brand<br/><span class="arabic"></span></td>
								<td width="32%" style="border:1pt solid grey;text-align:left;padding:2pt; ">Description<br/><span class="arabic"></span></td>
								<td width="12%" style="border:1pt solid grey;text-align:left;padding:2pt;">Unit Price<br/><span class="arabic"></span></td>
								<td width="15%" style="border:1pt solid grey;text-align:left;padding:2pt;">Quantity<br/><span class="arabic"></span></td>
								<td width="12%" style="border:1pt solid grey;text-align:left;padding:2pt;" >Taxable <br/> Amount<br/><span class="arabic">  </span></td>
								<td width="10%" style="border:1pt solid grey;text-align:left;padding:2pt;">Discount<br/><span class="arabic"></span></td>
								<td width="8%" style="border:1pt solid grey;text-align:left;padding:2pt;">Tax<br/><span class="arabic"> </span></td>
								<td width="12%" style="border:1pt solid grey;text-align:left;padding:2pt;">Total<br/><span class="arabic"></span></td>
							</tr></b>
						</thead>
					 	<t t-set="tax_total" t-value="0"/>
					 	<t t-set="discount_total" t-value="0"/>
						<tbody class="invoice_tbody">
						 	<tr t-foreach="o.order_line" t-as="l">
						 		<t t-set="line_tax_total" t-value="0"/>
					 			<t t-foreach="l.tax_id" t-as="t">
					 				<t t-set="tax_total" t-value="tax_total + l.price_subtotal* t.amount/100"/>
					 				<t t-set="line_tax_total" t-value="line_tax_total + t.amount"/>
					 			</t>
					 			<t t-set="discount_total" t-value="discount_total + ((l.price_unit * l.product_uom_qty) - l.price_subtotal)"/>
								<t t-if="not l.display_type">
									<td style="border-right:1pt solid grey;padding:1pt">
										<span t-field="l.product_template_id.categ_id.name"/>
									</td>
									<td style="border-right:1pt solid grey;padding:1pt">
										<span t-field="l.name"/><br/>
									</td>
									<td style="border-right:1pt solid grey;text-align:right;padding:3pt"><span t-field="l.price_unit" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
									<td style="border-right:1pt solid grey;text-align:center;padding:3pt"><span t-esc="'%.2f %s '%(l.product_uom_qty,l.product_uom.name)"/></td>

									<td style="padding:3pt;border-right:1pt solid grey;text-align:right;">
										<sapn t-esc="l.price_unit * l.product_uom_qty" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
									</td>

									<td style="border-right:1pt solid grey;text-align:right;padding:3pt;"  >
										<span t-field="l.discount" t-options='{"widget": "float", "precision": 2}'/> %
									 </td>

									<td style="border-right:1pt solid grey;padding:2pt;text-align:center;">
										<t t-foreach="l.tax_id" t-as="t">
											<span t-esc="'%.2f'%(t.amount)"/> %
										</t>
										<span t-if="not l.tax_id">0.0 %</span>
									</td>
									<td style="border-right:1pt solid grey;text-align:right;padding:3pt" >
										<span t-field="l.price_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
									</td>
								</t>
								<t t-elif="l.display_type == 'line_section'">
									<td name="td_section_line" colspan="99" style="background-color:#016feb;color:white;font-weight:bold">
										<span t-field="l.name"/>
									</td>
									<t t-set="current_section" t-value="l"/>
									<t t-set="current_subtotal" t-value="0"/>
								</t>
								<t t-elif="l.display_type == 'line_note'" style="background-color:#016feb;color:white;font-weight:bold">
									<td name="td_note_line" colspan="99">
										<span t-field="l.name"/>
									</td>
                           		</t>
						 	</tr>
		               	</tbody>
					</table>
					<table style="border:1pt solid grey;width:100%;color:black;margin-top:5px; color:black;" class="table table-bordered table-sm">
						<thead>
							<t t-set="discount_before_total" t-value="doc.amount_untaxed + discount_total"/>
							<tr class="text-center">
								<td class=""  style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">Total (Excluding VAT)</td>
								<td class="text-end arabic" style="border-right:1pt solid grey;text-align:right;padding:3pt">الإجمالي (غير شامل ضريبة القيمة المضافة)</td>
								<td style="border-right:1pt solid grey;text-align:right;padding:3pt" class="text-end"><span t-esc="discount_before_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
							</tr>
							<tr class="text-center">
								<td class="" style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt" >Discount</td>
								<td class="text-end arabic" style="border-right:1pt solid grey;text-align:right;padding:3pt">مجموع الخصم</td>
								<td style="border-right:1pt solid grey;text-align:right;padding:3pt" class="text-end"><span t-esc="discount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
							</tr>
							<tr>
								<td class="" style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">Total Taxable Amount (Excluding VAT)</td>
								<td class="text-end arabic" style="border-right:1pt solid grey;text-align:right;padding:3pt">إجمالي المبلغ الخاضع للضريبة (غير شامل ضريبة القيمة المضافة)</td>
								<td style="border-right:1pt solid grey;text-align:right;padding:3pt" class="text-end"><span t-esc="doc.amount_untaxed" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
							</tr>
							<tr>
								<td class="" style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">Total VAT</td>
								<td class="text-end arabic" style="border-right:1pt solid grey;text-align:right;padding:3pt">إجمالي ضريبة القيمة المضافة</td>
								<td style="border-right:1pt solid grey;text-align:right;padding:3pt" class="text-end"><span t-esc="tax_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
							</tr>
							<tr>
								<td class="" style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">Total Amount </td>
								<td class="text-end arabic" style="border-right:1pt solid grey;text-align:right;padding:3pt">إجمالي المبلغ </td>
								<td style="border-right:1pt solid grey;text-align:right;padding:3pt" class="text-end"><span t-esc="doc.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
							</tr>

						</thead>
					</table>
					<div class="row">
						<span t-field="o.note"/>

                    </div>
					</div>
				</div>
			</t>
		</t>
	</template>
	
	<template id="report_sale_order">
	    <t t-call="web.html_container">
	        <t t-foreach="docs" t-as="doc">
	            <t t-call="saudi_einvoice_knk.report_sale_order_document"/>
	        </t>
	    </t>
	</template>
</odoo>
