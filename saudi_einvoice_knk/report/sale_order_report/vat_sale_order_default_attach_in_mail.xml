<?xml version="1.0" ?>
<odoo>
    <data>
        <record id="email_template_edi_sale_order" model="mail.template">
            <field name="name">KSA_Quotation: Send by email</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="email_from">{{ (object.user_id.email_formatted or user.email_formatted)}}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="subject">{{ object.company_id.name}} Quotation (Ref {{object.name or 'n/a'}})</field>
            <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Dear
                    <t t-if="object.partner_id.parent_id">
                        <t t-out="object.partner_id.name or ''">Brandon Freeman</t> (<t t-out="object.partner_id.parent_id.name or ''">Azure Interior</t>),
                    </t>
                    <br /><br />
                    Please find our attached commercial offer
                    <br /><br />
                    Do not hesitate to contact us if you have any questions.
                    <br /><br />
                    Regards,
                </p>
            </div>
            </field>
            <field name="report_template" ref="saudi_einvoice_knk.action_report_sale_order"/>
            <field name="report_name">{{(object.company_id.name or '').replace('/','_')}}_Commercial_Offer_{{(object.name or '').replace('/','_')}}{{object.state == 'draft' and '_draft' or ''}}</field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
