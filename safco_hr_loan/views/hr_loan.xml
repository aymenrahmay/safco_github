
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_loan_tree_view" model="ir.ui.view">
        <field name="name">hr.loan.tree</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <list string="Loan Requests">
                <field name="type"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="loan_amount"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="hr_loan_form_view" model="ir.ui.view">
        <field name="name">hr.loan.form</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <form string="Loan / Deduction">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state != 'waiting_approval_1'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" groups="hr.group_hr_manager,hr.group_hr_user" invisible="state != 'waiting_approval_1'"/>
                    <button name="post_loan" type="object" string="Pay loan" class="btn-primary" groups="hr.group_hr_manager" invisible="state != 'approve'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_approval_1,approve,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="employee_id" readonly="state == 'approve' or state == 'paid'"/>
                            <field name="date"/>
                            <field name="department_id"/>
                            <field name="job_position"/>
                        </group>
                        <group>
                            <field name="loan_amount" readonly="state == 'approve' or state == 'paid'"/>
                            <field name="installment" readonly="state == 'approve' or state == 'paid'"/>
                            <field name="payment_date" readonly="state == 'approve' or state == 'paid'"/>
                            <field name="emp_account_id" invisible="state == 'draft'"/>
                            <field name="treasury_account_id" invisible="state == 'draft'"/>
                            <field name="journal_id" invisible="state == 'draft'"/>
                            <field name="account_move_id" readonly="1"/>
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                            <field name="currency_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        </group>
                        <group><field name="description"/></group>
                    </group>
                    <notebook>
                        <page string="Installments">
                            <field name="loan_lines">
                                <list string="Installments" editable="bottom">
                                    <field name="date"/>
                                    <field name="amount"/>
                                    <field name="paid" readonly="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="total_paid_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="balance_amount" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                            <button type="object" name="compute_installment" string="Compute Installment" groups="hr.group_hr_manager,hr.group_hr_user" class="oe_stat_button" icon="fa-clock-o" invisible="state == 'approve' or state == 'paid'"/>
                            <div class="oe_clear"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_loan_request_search_form" model="ir.ui.view">
        <field name="name">hr.loan.search.form</field>
        <field name="model">hr.loan</field>
        <field name="arch" type="xml">
            <search string="Loan">
                <filter string="My Loans" name="myloan" domain="[('employee_id.user_id.id', '=', uid)]"/>
                <field name="employee_id" string="Employee"/>
                <field name="department_id" string="Department"/>
                <filter string="Employee" name="employee_id_group" context="{'group_by':'employee_id'}"/>
                <filter string="Department" name="department_id_group" context="{'group_by':'department_id'}"/>
                <filter string="Status" name="status" context="{'group_by':'state'}"/>
            </search>
        </field>
    </record>
    <menuitem name="Loans And Deductions" id="menu_hr_loans_and_advances" web_icon="safco_hr_loan,static/description/loan_web.png" sequence="20"/>
    <record id="action_hr_loan_request" model="ir.actions.act_window">
        <field name="name">Loan Requests / Deductions</field>
        <field name="res_model">hr.loan</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myloan': 1}</field>
        <field name="search_view_id" ref="view_loan_request_search_form"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Click to create a new Loan request.</p>
            <p>Use this menu to create loan requests.</p>
        </field>
    </record>
    <menuitem name="Loan Requests" id="menu_base_hr_loan_request" parent="menu_hr_loans_and_advances" sequence="1"/>
    <menuitem name="Loan Requests" parent="menu_base_hr_loan_request" id="menu_hr_loan_request" action="action_hr_loan_request"/>
    <record id="act_hr_employee_loan_request" model="ir.actions.act_window">
        <field name="name">Loans</field>
        <field name="res_model">hr.loan</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myloan': 1, 'default_employee_id': active_id}</field>
        <field name="view_id" ref="hr_loan_tree_view"/>
        <field name="domain">[('employee_id', '=', active_id)]</field>
    </record>
    <record id="view_employee_form_loan_inherit" model="ir.ui.view">
        <field name="name">hr.employee.loan.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(act_hr_employee_loan_request)d" type="action" class="oe_stat_button" icon="fa-calendar" groups="hr.group_hr_manager,hr.group_hr_user">
                    <field name="loan_count" widget="statinfo" string="Loans"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
