<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<!--Adding a salary rule for loan-->
	<data noupdate="0">
        <record id="input_loan" model="hr.payslip.input.type">
            <field name="name">Loan</field>
            <field name="code">Loan</field>
            <field name="country_id" eval="False"/>
        </record>

        <record id="safco_hr_hr_salary_rule_LOANbfns" model="hr.salary.rule">
            <field name="amount_select">code</field>
            <field name="code">LO</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loan</field>
            <field name="sequence" eval="997"/>
            <field name="amount_python_compute">result = - (payslip.env['hr.payslip'].get_sum_lo_lines(payslip))</field>
            <field name="struct_id" ref="hr_payroll.hr_rule_basic"/>
         </record>



	</data>
</odoo>