<odoo>

    <record id="sale_safco_view_product_template_only_form_view" model="ir.ui.view">
        <field name="name">sale_safco.product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='standard_price']" position="replace">
                    <field name="standard_price" groups="account.group_account_manager"/>
            </xpath>
        </field>
    </record>

    <record id="sale_safco_product_template_tree_view" model="ir.ui.view">
      <field name="name">product.template.sale_safco.tree</field>
      <field name="model">product.template</field>
      <field name="inherit_id" ref="product.product_template_tree_view"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='standard_price']" position="replace">
        </xpath>
      </field>
    </record>

    <record id="sale_safco_product_product_form_view" model="ir.ui.view">
            <field name="name">product.product.sale_safco.tree</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='standard_price']" position="replace">
                    <field name="standard_price" groups="account.group_account_manager"/>
            </xpath>
            </field>
        </record>






</odoo>
