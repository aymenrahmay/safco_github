<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="safco_account_invoice_view_tree_extend" model="ir.ui.view">
            <field name="name">account.invoice.tree.extend</field>
            <field name="model">account.move</field> <!-- Remplacez account.invoice par account.move -->
            <field name="inherit_id" ref="account.view_move_tree"/> <!-- Remplacez account.invoice_tree_with_onboarding par account.view_move_tree -->
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="partner_vat"/>
                </xpath>
            </field>
        </record>

        <record id="safco_account_invoice_view_form_taxes" model="ir.ui.view">
            <field name="name">tax.account.invoice</field>
            <field name="model">account.move</field> <!-- Remplacez account.invoice par account.move -->
            <field name="inherit_id" ref="account.view_move_form"/> <!-- Remplacez account.invoice_form par account.view_move_form -->
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='discount']" position="replace">
                </xpath>
                <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='price_unit']" position="after">
                    <field name="discount"/>

                </xpath>

                <field name="invoice_origin" position="replace"/>
                <field name="invoice_payment_term_id" position="after">
                    <field name="invoice_origin"/>
                </field>
            </field>
        </record>
    </data>
</odoo>