<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="z_mrp_tree_report">
            <t t-call="web.html_container">
                 <h3><center> Production orders </center></h3>
                <br/>
                Printed By:
                <span t-field="user.name"/>
                <br/>
                Print date/time:
                <span t-esc="time.strftime('%Y-%m-%d %H:%M:%S')"/>
                <br/>
                    <table style="width: 900px;" border ='1'>
                        <p></p>
                                <tbody>
                                    <tr>
                                        <td style="width: 138px;">
                                            <strong>Order name</strong>
                                        </td>
                                        <td style="width: 175px;">
                                            <strong>Product</strong>
                                        </td>
                                        <td style="width: 138px;">
                                            <strong>Qty/uom</strong>
                                        </td>

                                        <td style="width: 120px;">
                                            <strong>Approved by</strong>
                                        </td>
                                         <td style="width: 120px;">
                                            <strong>Approval date</strong>
                                        </td>
                                    </tr>
                                     <t t-foreach="docs" t-as="o">
                                        <tr>
                                            <td style="width: 138px;"> <span t-field="o.name"/> </td>
                                            <td style="width: 175px;"> <span t-field="o.product_id.name"/> </td>
                                            <td style="width: 138px;"> <span t-field="o.product_qty"/> - <span t-field="o.product_uom_id.name"/>  </td>

                                            <td style="width: 120px;"> <span t-field="o.user_id.name"/> </td>
                                            <td style="width: 120px;"> <span t-field="o.date_planned_start"/> </td>
                                        </tr>
                                      </t>
                                </tbody>
                            </table>

                </t>


        </template>
    </data>
</odoo>