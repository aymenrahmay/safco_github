<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <template id="z_mrp_bom_request_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div style="border: 1px solid black;">
                        <div class="header">
                            <table style="width:1100px;background-color:#DCDCDC;" border="2">
                                <tr>
                                    <td rowspan="4" style="width:15%;vertical-align: middle;text-align: center;background-color:#FFF;">
                                        <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height:90pt;max-width:120%" alt="Company Logo"/>
                                    </td>
                                    <td rowspan="2" style="width:60%; height: 46px; valign=top;" >
                                        <center>
                                            <strong>
                                                <span t-field="o.company_id.name"/> <br></br><br></br>RAW MATERIAL REQUEST FORM
                                            </strong>
                                        </center>
                                    </td>
                                    <td style="width:15%;valign=top;">
                                        DOC  NO:<br></br>
                                        REV.NO:<br></br>
                                        DATE:<br></br>
                                        PAGE:
                                    </td>
                                    <td style="width:15%;valign=top;">
                                        FM-QC-25<br></br>
                                        0<br></br>
                                        <span t-field="o.date_planned_start"  t-options='{"widget": "date"}'/><br></br>
                                        1 of 1
                                    </td>
                                </tr>

                            </table>
                        </div>
                        <div class="page">
                            <table  style="width:1100px;" border="2">
                                <tr>
                                    <td style="width:15%;"><strong>Request No.</strong></td>
                                    <td style="width:35%;"> </td>
                                    <td style="width:15%;"><strong>Date :</strong></td>
                                    <td style="width:35%;"><span t-field="o.date_planned_start"  t-options='{"widget": "date"}'/></td>
                                </tr>
                                <tr>
                                    <td><strong>Product Name :</strong></td>
                                    <td><span t-field="o.product_id.name"/></td>
                                    <td><strong>Batch Volume</strong></td>
                                    <td><span/><span t-field="o.product_qty"/></td>
                                </tr>
                                <tr>
                                    <td><strong>Batch No.</strong></td>
                                    <td><span/><span t-field="o.name"/></td>
                                    <td><strong>Scale Serial No.</strong></td>
                                    <td><span/></td>
                                </tr>
                            </table>
                            <br/><br/>
                            <b>From Location:</b><span t-field="o.location_src_id.name"/>
                            <br/><br/>
                            <b>To Location:</b><span t-field="o.location_src_id.name"/>
                            <br/><br/><br/><br/>
                            <table  style="width:1100px;" border="2">
                                <thead style="background-color:#DCDCDC;">
                                    <td><strong>S. NO</strong></td>
                                    <td><strong>IDH CODE</strong></td>
                                    <td style="width:50%;"><strong>Raw Material</strong></td>
                                    <td><strong>Required Qty. (kg)</strong></td>
                                    <td><strong>Added Qty. (kg)</strong></td>
                                    <td><strong>Weight confirmed by store</strong></td>
                                </thead>
                                <t t-set="count" t-value="0"/>
                                <t t-foreach="o.move_raw_ids" t-as="raw">
                                    <t t-set="count" t-value="count + 1"/>
                                    <tr>
                                        <td><span t-esc="count"/></td>
                                        <td><span t-field="raw.product_id.id"/></td>
                                        <td><span t-field="raw.product_id.name"/></td>
                                        <td><span t-field="raw.product_qty"/></td>
                                        <td><span t-field="raw.product_qty"/></td>
                                        <td><span t-field="raw.name"/></td>
                                    </tr>
                                </t>
                            </table><br></br><br></br>
                            <table  style="width:500px;" border="2">
                                <tr>
                                    <td style="width:50%; background-color:#DCDCDC;"><strong>Production Manager :</strong></td>
                                    <td><span/></td>
                                </tr>
                                <tr>
                                    <td style="width:50%; background-color:#DCDCDC;"><strong>Quality Manager :</strong></td>
                                    <td><span/></td>
                                </tr>
                                <tr>
                                    <td style="width:50% ; background-color:#DCDCDC;"><strong>Mixing Operator :</strong></td>
                                    <td><span/></td>
                                </tr>
                                <tr>
                                    <td style="width:50%; background-color:#DCDCDC;"><strong>Storekeeper :</strong></td>
                                    <td><span/></td>
                                </tr>
                            </table>

                        </div>
                        <div class="footer">

                        </div>
                    </div>
                </t>
            </t>

        </template>
    </data>
</openerp>