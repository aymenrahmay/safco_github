<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="mrp_production_form_view_safco" model="ir.ui.view">
            <field name="name">mrp.production.form.safco</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="after">
                    <field name="vise_number"/>
                    <field name="date_finished"/>
                    <field name="location_src_id" readonly="1"/>
                    <field name="location_dest_id" readonly="1"/>
                </xpath>

                <xpath expr="//field[@name='move_raw_ids']" position="after">
                    <group string="Quality Control">
                        <group>
                            <field name="verified_by"/>
                            <field name="mixing_operator"/>
                            <field name="confirmation_date_time"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="remarks"/>
                        </group>
                        <group>
                            <field name="ph"/>
                            <field name="sp"/>
                            <field name="color"/>
                        </group>
                        <group>
                            <field name="od"/>
                            <field name="refractive"/>
                            <field name="other"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="mrp_report_list_view_safco" model="ir.ui.view">
            <field name="name">mrp.report.tree.safco</field>
            <field name="model">mrp.report</field>
            <field name="inherit_id" ref="mrp_account_enterprise.mrp_report_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='production_id']" position="after">
                    <field name="qty_produced"/>
                    <field name="unit_cost"/>
                    <field name="total_cost"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
